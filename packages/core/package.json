{
  "name": "@blenx-dev/core",
  "version": "0.3.3",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./icons": {
      "types": "./src/icons/index.ts",
      "default": "./src/icons/index.ts"
    },
    "./*": "./src/components/*/index.ts",
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*",
      "default": "./src/components/*"
    },
    "./utils/*": {
      "types": "./src/utils/*",
      "default": "./src/utils/*"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen:icons": "tsx scripts/generate-icons.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@blenx-dev/theme": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "clsx": "^2.1.1",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.493",
    "@iconify/tools": "^5.0.12",
    "@iconify/types": "^2.0.0",
    "@iconify/utils": "^3.1.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "changeset": "^0.2.6",
    "prettier": "^3.9.3",
    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "@blenx-dev/theme": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
