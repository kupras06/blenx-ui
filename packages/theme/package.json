{
  "name": "@blenx-dev/theme",
  "version": "0.2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./contract": {
      "types": "./src/contract.css.ts",
      "default": "./src/contract.css.ts"
    },
    "./tokens": {
      "types": "./src/tokens.css.ts",
      "default": "./src/tokens.css.ts"
