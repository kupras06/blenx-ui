{
  "name": "@blenx-dev/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./lib/*": {
      "types": "./src/lib/*",
      "default": "./src/lib/*"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*",
      "default": "./src/components/*"
    },
    "./utils/*": {
      "types": "./src/utils/*",
      "default": "./src/utils/*"
    },
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "vite build && cp package.build.json dist/package.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@blenx-dev/theme": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-table": "^8.21.3",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "clsx": "^2.1.1",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@blenx-dev/config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "tailwindcss": "^4.1.18",
    "typescript": "catalog:"
  }
}
