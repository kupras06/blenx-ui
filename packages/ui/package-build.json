{
  "name": "@blenx-dev/ui",
  "version": "0.0.0",
  "private": true,
  "files": ["dist"],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#utils/*": "./src/utils/*",
    "#theme/*": "./src/theme/*"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/assets/stylex.css",
    "./components/*": {
      "source": "./src/components/index.ts",
      "types": "./dist/src/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./theme/*": {
      "source": "./src/theme/*.ts",
      "types": "./dist/src/theme/*.d.ts",
      "import": "./dist/theme/*.js"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build:vite": "vite build",
    "generate:api": "bun run scripts/generate-api.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@stylexjs/stylex": "^0.19.0",
    "@stylexjs/unplugin": "^0.19.0",
    "@tanstack/react-table": "^8.21.3",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-colorful": "^5.7.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "catalog:",
    "sonner": "^2.0.5"
  },
  "devDependencies": {
    "@blenx-dev/config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "esbuild": "^0.28.1",
    "react-docgen-typescript": "^2.4.0",
    "tailwindcss": "^4.1.18",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  },
  "peerDependencies": {
    "@stylexjs/stylex": "^0.19.0"
  }
}
