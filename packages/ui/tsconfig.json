{
  "extends": "@blenx-dev/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [],
    "paths": {
      "#utils/*": ["./src/utils/*"],
      "#theme/*": ["./src/theme/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
