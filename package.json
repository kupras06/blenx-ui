{
  "name": "blenx-ui",
  "private": true,
  "type": "module",
  "keywords": [
    "stylex",
    "base-ui",
    "react",
    "react-components",
    "component-library",
    "ui-kit",
    "design-system",
    "no-tailwind",
    "shadcn",
    "modern",
    "typescript",
    "zustand",
    "components",
    "ui-components"
  ],
  "scripts": {
    "dev": "vite dev --host",
    "generate-routes": "tsr generate",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "build": "bun run sitemap && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "check:fix": "biome check --write",
    "registry:gen": "tsx registry/build.ts",
    "registry:build": "bun registry:gen && shadcn build registry/registry.json --output public/reg && bun registry/clean.ts",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@phosphor-icons/react": "^2.1.10",
    "@stylexjs/stylex": "^0.18.3",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@uidotdev/usehooks": "^2.4.1",
    "@vercel/og": "^0.11.1",
    "lucide-react": "^0.545.0",
    "nitro": "^3.0.260610-beta",
    "react": "^19.2.0",
    "react-colorful": "^5.7.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.14",
    "zustand-utils": "^2.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@stylexjs/unplugin": "^0.18.3",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "shadcn": "^4.11.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
