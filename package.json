{
	"name": "blenx-ui",
	"private": true,
	"keywords": [
		"base-ui",
		"component-library",
		"components",
		"design-system",
		"modern",
		"no-tailwind",
		"react",
		"react-components",
		"shadcn",
		"stylex",
		"typescript",
		"ui-components",
		"ui-kit",
		"zustand"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"generate-routes": "bun run docs:build && tsr generate",
		"sitemap": "tsx scripts/generate-sitemap.ts",
		"docs:build": "bun run registry:build && tsx scripts/generate-docs-manifest.ts",
		"build": "bun run docs:build && bun run sitemap && vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"format": "oxfmt .",
		"format:check": "oxfmt --check src/",
		"lint": "oxlint src/",
		"check": "oxlint src/ && oxfmt --check src/",
		"check:fix": "oxlint --fix src/ && oxfmt src/",
		"registry:gen": "tsx scripts/build.ts",
		"generate-responsive-grid": "tsx scripts/generate-responsive-grid.ts",
		"registry:build": "bun registry:gen && shadcn build scripts/registry.json --output public/reg && bun scripts/clean.ts",
		"deploy": "bun run build && wrangler deploy"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@cloudflare/vite-plugin": "^1.26.0",
		"@phosphor-icons/react": "^2.1.10",
		"@stylexjs/stylex": "^0.19.0",
		"@t3-oss/env-core": "^0.13.10",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-query": "^5.101.0",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/router-plugin": "^1.132.0",
		"@uidotdev/usehooks": "^2.4.1",
		"@vercel/og": "^0.11.1",
		"lucide-react": "^0.545.0",
		"nitro": "^3.0.260610-beta",
		"react": "^19.2.0",
		"react-colorful": "^5.7.0",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.0",
		"shiki": "^4.2.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.14",
		"zustand-utils": "^2.1.1"
	},
	"devDependencies": {
		"@babel/generator": "^8.0.0",
		"@stylexjs/unplugin": "^0.19.0",
		"@tanstack/devtools-vite": "latest",
		"@tanstack/router-cli": "^1.132.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^28.1.0",
		"oxfmt": "^0.55.0",
		"oxlint": "^1.70.0",
		"shadcn": "^4.11.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.22.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.0",
		"vitest": "^4.1.5",
		"wrangler": "^4.70.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss"
		]
	}
}
