{
  "name": "blenx-dev",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo dev",
    "check": "oxlint && oxfmt --write",
    "clean": "rimraf --glob node_modules dist build .turbo **/node_modules **/dist **/build && turbo -F clean",
    "generate:registry": "tsx scripts/generate-docs-manifest.ts",
    "generate:api": "tsx scripts/generate-api-meta.ts"
  },
  "dependencies": {
    "@blenx-dev/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@blenx-dev/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "rimraf": "^6.1.3",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
