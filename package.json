{
  "name": "blenx-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "registry:gen": "ts-node registry/build.ts",
    "registry:build": "bun registry:gen && shadcn build registry/registry.json --output public/reg && bun registry/clean.ts",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
